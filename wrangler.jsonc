{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "jumo-link-fixer",
  "main": "src/index.ts",
  "compatibility_date": "2025-10-08",
  "workers_dev": false,
  "routes": [
    {
      "pattern": "*.jumo.dev/*",
      "zone_id": "90ca6b1933f110bb11d87d4f0a66e0b7"
    }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "ENVIRONMENT": "dev",
    "BROWSERBASE_FUNCTION_ID": "YOUR_FUNCTION_ID_HERE"
  },
  "env": {
    "staging": {
      "vars": {
        "ENVIRONMENT": "staging",
        "BROWSERBASE_FUNCTION_ID": "YOUR_FUNCTION_ID_HERE"
      }
    },
    "production": {
      "vars": {
        "ENVIRONMENT": "production",
        "BROWSERBASE_FUNCTION_ID": "YOUR_FUNCTION_ID_HERE"
      }
    }
  },
  // "kv_namespaces": [
  //   {
  //     "binding": "MY_KV_NAMESPACE",
  //     "id": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
  //   }
  // ],
  // "r2_buckets": [
  //   {
  //     "binding": "MY_BUCKET",
  //     "bucket_name": "my-bucket"
  //   }
  // ],
  // "d1_databases": [
  //   {
  //     "binding": "MY_DB",
  //     "database_name": "my-database",
  //     "database_id": ""
  //   }
  // ],
  // "ai": {
  //   "binding": "AI"
  // },
  // "observability": {
  //   "enabled": true,
  //   "head_sampling_rate": 1
  // }
}